@{
    ViewData["Title"] = "Finans ve Takip";
    string role = ViewBag.Role as string;
}

<div class="container mt-4">
    
    @if (role == "Admin")
    {
        <h2 class="mb-4">Sistem Genel İşlem Geçmişi</h2>
        <div class="card bg-dark text-white mb-4 shadow">
            <div class="card-body">
                <h5>Platform Toplam Hacmi</h5>
                <h2>@ViewBag.TotalSystemVolume.ToString("C")</h2>
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-md-6 offset-md-3">
                <canvas id="financeChart"></canvas>
            </div>
        </div>

        <div class="table-responsive shadow-sm">
            <table class="table table-hover table-bordered bg-white">
                <thead class="table-dark">
                    <tr>
                        <th>Araç</th>
                        <th>Sahibi (Kiralayan)</th>
                        <th>Müşteri (Kiralayan)</th>
                        <th>Başlangıç</th>
                        <th>Bitiş</th>
                        <th>Tutar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var r in ViewBag.AllTransactions) {
                        <tr>
                            <td><strong>@r.Car.Brand</strong> @r.Car.Model</td>
                            <td><span class="badge bg-secondary">@r.Car.Owner.Username</span></td>
                            <td><span class="badge bg-primary">@r.User.Username</span></td>
                            <td>@r.StartDate.ToShortDateString()</td>
                            <td>@r.EndDate.ToShortDateString()</td>
                            <td class="text-success fw-bold">@r.TotalPrice.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <h2 class="mb-4">Finansal Durumum</h2>
        <div class="row">
            <div class="col-md-6">
                <div class="card bg-success text-white mb-3 shadow">
                    <div class="card-body">
                        <h5>Toplam Gelir (Kiralattığım)</h5>
                        <h2>@ViewBag.TotalIncome.ToString("C")</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card bg-danger text-white mb-3 shadow">
                    <div class="card-body">
                        <h5>Toplam Gider (Kiraladığım)</h5>
                        <h2>@ViewBag.TotalExpense.ToString("C")</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-5 mt-4">
            <div class="col-md-4 offset-md-4">
                <canvas id="financeChart"></canvas>
            </div>
        </div>

        @if (role == "Kiralayıcı")
        {
            <h4 class="mt-4">Gelir Detayları (Benim Araçlarım)</h4>
            <table class="table table-striped bg-white shadow-sm">
                <thead class="table-success"><tr><th>Araç</th><th>Kiralayan</th><th>Tarih</th><th>Kazanç</th></tr></thead>
                <tbody>
                    @foreach(var r in ViewBag.Incomes) {
                        <tr><td>@r.Car.Brand</td><td>@r.User.Username</td><td>@r.StartDate.ToShortDateString()</td><td>@r.TotalPrice.ToString("C")</td></tr>
                    }
                </tbody>
            </table>
        }

        <h4 class="mt-4">Gider Detayları (Kiraladıklarım)</h4>
        <table class="table table-striped bg-white shadow-sm mb-5">
            <thead class="table-danger"><tr><th>Araç</th><th>Sahibi</th><th>Tarih</th><th>Maliyet</th></tr></thead>
            <tbody>
                @foreach(var r in ViewBag.Expenses) {
                    <tr><td>@r.Car.Brand</td><td>@r.Car.Owner.Username</td><td>@r.StartDate.ToShortDateString()</td><td>@r.TotalPrice.ToString("C")</td></tr>
                }
            </tbody>
        </table>
    }
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var ctx = document.getElementById('financeChart').getContext('2d');
        
        var role = '@role';
        var chartLabels = [];
        var chartData = [];
        var chartColors = [];

        if (role === 'Admin') {
            chartLabels = ['Platform Toplam Hacmi'];
            // C# Decimal değerlerini JS Float'a çeviriyoruz
            var totalVol = parseFloat('@ViewBag.TotalSystemVolume'.replace(',', '.'));
            chartData = [totalVol];
            chartColors = ['#212529'];
        } else {
            chartLabels = ['Toplam Gelir', 'Toplam Gider'];
            // C# Decimal değerlerini JS Float'a çeviriyoruz
            var totalInc = parseFloat('@ViewBag.TotalIncome'.replace(',', '.'));
            var totalExp = parseFloat('@ViewBag.TotalExpense'.replace(',', '.'));
            chartData = [totalInc, totalExp];
            chartColors = ['#198754', '#dc3545'];
        }

        var financeChart = new Chart(ctx, {
            type: 'pie',
            data: {
                labels: chartLabels,
                datasets: [{
                    data: chartData,
                    backgroundColor: chartColors,
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' },
                    title: { display: true, text: 'Finansal Dağılım Grafiği', font: { size: 16 } }
                }
            }
        });
    });
</script>