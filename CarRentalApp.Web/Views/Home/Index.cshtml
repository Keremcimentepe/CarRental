@model IEnumerable<CarRentalApp.Models.Entities.Car>
@{
    ViewData["Title"] = "Ana Sayfa";
    var currentUser = ViewBag.CurrentUser as CarRentalApp.Models.Entities.User;
}

<div class="container mt-4">
    <div class="row bg-light p-4 rounded shadow-sm mb-4 align-items-center">
        @if (User.Identity.IsAuthenticated && currentUser != null)
        {
            <div class="col-md-2 text-center">
                @if (currentUser.ProfilePicture != null && currentUser.ProfilePicture.Length > 0)
                {
                    string base64String = Convert.ToBase64String(currentUser.ProfilePicture);
                    string imageSrc = $"data:image/jpeg;base64,{base64String}";
                    <img src="@imageSrc" class="rounded-circle img-thumbnail shadow-sm" style="width: 120px; height: 120px; object-fit: cover;" alt="Profil Resmi" />
                }
                else
                {
                    <img src="https://cdn-icons-png.flaticon.com/512/149/149071.png" class="rounded-circle img-thumbnail shadow-sm" style="width: 120px; height: 120px; object-fit: cover;" alt="Varsayılan Profil" />
                }
            </div>
            <div class="col-md-7">
                <h2>Hoş Geldin, @currentUser.Username!</h2>
                <p class="text-muted mb-0">Rol: <span class="badge bg-info">@currentUser.Role</span></p>
            </div>
            <div class="col-md-3 text-end d-flex flex-column gap-2">
                @if (currentUser.Role == "Admin")
                {
                    <a asp-controller="Car" asp-action="Pending" class="btn btn-warning w-100 fw-bold">🚨 Onay Bekleyenler</a>
                }
                <a asp-controller="Profile" asp-action="Index" class="btn btn-info w-100">Finans Takibi (Gelir/Gider)</a>
                <a asp-controller="Auth" asp-action="Logout" class="btn btn-danger w-100">Çıkış Yap</a>
            </div>
        }
        else
        {
            <div class="col-md-8">
                <h2>Araç Kiralama Platformuna Hoş Geldiniz!</h2>
                <p class="text-muted mb-0">Araçları inceleyebilir, detaylarına bakabilirsiniz. Kiralamak veya ilan vermek için giriş yapmalısınız.</p>
            </div>
            <div class="col-md-4 text-end d-flex flex-column gap-2">
                <a asp-controller="Auth" asp-action="Login" class="btn btn-primary w-100 btn-lg">Giriş Yap / Kayıt Ol</a>
            </div>
        }
    </div>

    <hr />

    <div class="row mb-3 align-items-center">
        <div class="col-md-12 d-flex align-items-center justify-content-between">
            <h3 class="mb-0">Araç Listesi</h3>
            @if (User.Identity.IsAuthenticated && currentUser?.Role == "Kiralayıcı")
            {
                <a asp-controller="Car" asp-action="Create" class="btn btn-success">+ Yeni Araç Ekle</a>
            }
        </div>
    </div>

    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-body bg-light">
            <form asp-controller="Home" asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small fw-bold">Marka</label>
                    <input type="text" name="brand" value="@ViewBag.Brand" class="form-control" placeholder="Örn: BMW">
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold">Model</label>
                    <input type="text" name="model" value="@ViewBag.Model" class="form-control" placeholder="Örn: M5">
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold">Min Fiyat</label>
                    <input type="number" name="minPrice" value="@ViewBag.MinPrice" class="form-control" placeholder="0">
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold">Max Fiyat</label>
                    <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" class="form-control" placeholder="5000">
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold">Müsaitlik</label>
                    <select name="isAvailable" class="form-select">
                        <option value="">Tümü</option>
                        <option value="true" selected="@(ViewBag.IsAvailable == true ? "selected" : null)">Sadece Müsaitler</option>
                        <option value="false" selected="@(ViewBag.IsAvailable == false ? "selected" : null)">Kiradakiler</option>
                    </select>
                </div>
                <div class="col-md-2 d-grid gap-2">
                    <button type="submit" class="btn btn-primary">Filtrele</button>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">Temizle</a>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm mb-4">
        <table class="table table-hover table-bordered align-middle bg-white mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Resim</th>
                    <th>Araç Bilgisi</th>
                    <th>Yükleyen (Sahibi)</th>
                    <th>Günlük Fiyat</th>
                    <th>Durum / Müsaitlik</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var car in Model)
                    {
                        <tr>
                            <td>
                                @if (car.Image != null && car.Image.Length > 0)
                                {
                                    string carBase64 = Convert.ToBase64String(car.Image);
                                    string carImageSrc = $"data:image/jpeg;base64,{carBase64}";
                                    <img src="@carImageSrc" class="img-thumbnail shadow-sm" style="width: 150px; height: 100px; object-fit: cover;" alt="Araç Resmi" />
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center bg-light rounded shadow-sm" style="width: 150px; height: 100px; border: 1px dashed #ccc;">
                                        <small class="text-muted fw-bold" style="font-size: 12px;">RESİM YOK</small>
                                    </div>
                                }
                            </td>
                            
                            <td>
                                <strong style="font-size: 1.1rem;">@car.Brand</strong><br />
                                <span class="text-muted">@car.Model (@car.Year)</span>
                            </td>
                            
                            <td>
                                <span class="badge bg-secondary">@(car.Owner?.Username ?? "Bilinmiyor")</span>
                            </td>
                            
                            <td class="fw-bold text-success">@car.DailyPrice.ToString("C")</td>
                            
                            <td>
                                @if (car.IsAvailable)
                                {
                                    <span class="badge bg-success w-100">Hemen Müsait</span>
                                }
                                else
                                {
                                    <div class="text-center">
                                        <span class="badge bg-danger w-100 mb-1">Kirada</span>
                                        <br/>
                                        <small class="text-muted fw-bold">Dönüş: @(car.Rentals?.OrderByDescending(r => r.EndDate).FirstOrDefault()?.EndDate.ToShortDateString() ?? "Bilinmiyor")</small>
                                    </div>
                                }
                            </td>
                            
                            <td>
                                @if (!User.Identity.IsAuthenticated)
                                {
                                    <a asp-controller="Auth" asp-action="Login" class="btn btn-sm btn-outline-primary">Kiralamak İçin Giriş Yap</a>
                                }
                                else
                                {
                                    @if (currentUser?.Role != "Admin")
                                    {
                                        if (car.IsAvailable)
                                        {
                                            <a asp-controller="Rental" asp-action="Create" asp-route-carId="@car.Id" class="btn btn-sm btn-primary">Kirala</a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-secondary" disabled>Kirada</button>
                                        }
                                    }

                                    @if (currentUser?.Role == "Admin" || (currentUser?.Role == "Kiralayıcı" && car.OwnerId == currentUser?.Id))
                                    {
                                        <a asp-controller="Car" asp-action="Edit" asp-route-id="@car.Id" class="btn btn-sm btn-warning ms-1">Düzenle</a>
                                        
                                        <form asp-controller="Car" asp-action="Delete" asp-route-id="@car.Id" method="post" style="display:inline;" onsubmit="return confirm('Bu aracı silmek istediğinize emin misiniz?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger ms-1">Sil</button>
                                        </form>
                                    }
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted p-5">
                            <h5>Arama kriterlerine uygun araç bulunamadı.</h5>
                            <p>Lütfen farklı filtreler deneyin.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Araç listesi sayfaları">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" 
                           asp-route-page="@i" 
                           asp-route-brand="@ViewBag.Brand" 
                           asp-route-model="@ViewBag.Model"
                           asp-route-minPrice="@ViewBag.MinPrice"
                           asp-route-maxPrice="@ViewBag.MaxPrice"
                           asp-route-isAvailable="@ViewBag.IsAvailable">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>