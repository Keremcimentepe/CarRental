@{
    var car = ViewBag.Car as CarRentalApp.Models.Entities.Car;
    ViewData["Title"] = "Araç Kirala";
}

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">@car.Brand @car.Model Kirala</h4>
        </div>
        <div class="card-body">
            
            <!-- CONTROLLER'DAN GELEN HATA MESAJI ALANI -->
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger fw-bold shadow-sm" role="alert">
                    @ViewBag.ErrorMessage
                </div>
            }

            <div class="row">
                <div class="col-md-4 text-center mb-3">
                    @if (car.Image != null)
                    {
                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(car.Image)" class="img-fluid rounded shadow-sm" alt="Araç Resmi" />
                    }
                    else
                    {
                        <div class="bg-light p-5 rounded text-muted">Resim Yok</div>
                    }
                </div>
                <div class="col-md-8">
                    <form asp-action="Create" method="post">
                        <input type="hidden" name="carId" value="@car.Id" />
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Başlangıç Tarihi</label>
                            <!-- Takvimden 3 günden sonrasını seçmesi HTML seviyesinde kısıtlandı -->
                            <input type="date" name="startDate" class="form-control" required 
                                   min="@DateTime.Now.ToString("yyyy-MM-dd")" 
                                   max="@DateTime.Now.AddDays(3).ToString("yyyy-MM-dd")" />
                            <small class="text-muted">En geç 3 gün sonrasına rezervasyon yapabilirsiniz.</small>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Bitiş Tarihi</label>
                            <!-- Bitiş tarihi en erken yarın seçilebilir -->
                            <input type="date" name="endDate" class="form-control" required 
                                   min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" />
                            <small class="text-muted">Maksimum kiralama süresi 30 gündür.</small>
                        </div>

                        <div class="alert alert-info">
                            Araç Günlük Kiralama Bedeli: <strong>@car.DailyPrice.ToString("C")</strong>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg">Kiralamayı Onayla</button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Vazgeç ve Ana Sayfaya Dön</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>