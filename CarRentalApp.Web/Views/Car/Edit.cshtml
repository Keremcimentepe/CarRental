@model CarRentalApp.Models.Entities.Car
@{
    ViewData["Title"] = "Araç Güncelle";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-warning text-dark py-3">
                    <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Araç Bilgilerini Güncelle</h4>
                </div>
                <div class="card-body p-4">
                    
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger fw-bold shadow-sm" role="alert">
                            ⚠️ @ViewBag.ErrorMessage
                        </div>
                    }

                    <form asp-controller="Car" asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-secondary">Marka</label>
                                <input asp-for="Brand" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-secondary">Model</label>
                                <input asp-for="Model" class="form-control" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-secondary">Üretim Yılı</label>
                                <input asp-for="Year" type="number" class="form-control" min="1980" max="2026" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-secondary">Günlük Kiralama Fiyatı (₺)</label>
                                <input asp-for="DailyPrice" type="number" step="0.01" class="form-control" min="1000" max="100000" required />
                            </div>
                        </div>

                        <div class="mb-4 p-3 bg-light border rounded-3">
                            <label class="form-label fw-bold text-primary">Yeni Araç Fotoğrafı Yükle</label>
                            <input type="file" name="carImage" class="form-control" accept="image/*" />
                            <small class="text-muted d-block mt-1">Mevcut resmi değiştirmek istemiyorsanız bu alanı boş bırakın.</small>
                        </div>

                        <div class="form-check form-switch mb-4 fs-5">
                            <input asp-for="IsAvailable" class="form-check-input" type="checkbox" id="flexSwitchEdit" />
                            <label class="form-check-label fw-bold text-success" for="flexSwitchEdit">Araç Kiralamaya Müsait</label>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">İptal</a>
                            <button type="submit" class="btn btn-warning btn-lg px-5 fw-bold">Değişiklikleri Kaydet</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>