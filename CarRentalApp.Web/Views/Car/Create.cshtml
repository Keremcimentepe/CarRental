@model CarRentalApp.Models.Entities.Car
@{
    ViewData["Title"] = "Yeni Araç Ekle";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Sisteme Yeni Araç Ekle</h4>
                </div>
                <div class="card-body">
                    
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger fw-bold" role="alert">
                            ⚠️ @ViewBag.ErrorMessage
                        </div>
                    }

                    <form asp-controller="Car" asp-action="Create" method="post" enctype="multipart/form-data">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Marka</label>
                                <input asp-for="Brand" class="form-control" placeholder="Örn: BMW" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Model</label>
                                <input asp-for="Model" class="form-control" placeholder="Örn: 320i" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Üretim Yılı</label>
                                <input asp-for="Year" type="number" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Günlük Kiralama Fiyatı (₺)</label>
                                <input asp-for="DailyPrice" type="number" step="0.01" class="form-control" required />
                            </div>
                        </div>

                        <div class="mb-4 p-3 bg-light border rounded">
                            <label class="form-label fw-bold text-danger">Araç Fotoğrafı (Zorunlu)</label>
                            <input type="file" name="carImage" class="form-control border-danger" accept="image/*" required />
                            <small class="text-muted">Lütfen aracın net bir fotoğrafını yükleyin.</small>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="IsAvailable" class="form-check-input" type="checkbox" checked />
                            <label class="form-check-label fw-bold">Araç Şu An Kiralamaya Müsait</label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg">Aracı Kaydet ve Yayınla</button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">İptal Et</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>