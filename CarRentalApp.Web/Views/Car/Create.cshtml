@model CarRentalApp.Models.Entities.Car
@{
    ViewData["Title"] = "Yeni Araç Ekle";
}

<div class="container mt-4">
    <h2>Yeni Araç Ekle</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-controller="Car" asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label">Marka</label>
                    <input asp-for="Brand" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Model</label>
                    <input asp-for="Model" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Üretim Yılı</label>
                    <input asp-for="Year" type="number" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Günlük Kiralama Fiyatı (₺)</label>
                    <input asp-for="DailyPrice" type="number" step="0.01" class="form-control" required />
                </div>
                <div class="form-check mb-3">
                    <input asp-for="IsAvailable" class="form-check-input" type="checkbox" checked />
                    <label class="form-check-label">Araç Kiralamaya Müsait</label>
                </div>
                <div class="mb-3">
    <label class="form-label">Araç Fotoğrafı</label>
    <input type="file" name="carImage" class="form-control" accept="image/*" />
</div>
                <button type="submit" class="btn btn-primary">Kaydet</button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">İptal</a>
            </form>
        </div>
    </div>
</div>