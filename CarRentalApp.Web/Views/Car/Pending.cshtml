@model IEnumerable<CarRentalApp.Models.Entities.Car>
@{
    ViewData["Title"] = "Onay Bekleyen Araçlar";
}

<div class="container mt-4">
    <h2><i class="bi bi-clock-history"></i> Onay Bekleyen İlanlar</h2>
    <hr />

    <div class="table-responsive shadow-sm">
        <table class="table table-hover table-bordered align-middle bg-white">
            <thead class="table-warning">
                <tr>
                    <th>Resim</th>
                    <th>Araç Bilgisi</th>
                    <th>Yükleyen</th>
                    <th>Günlük Fiyat</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var car in Model)
                    {
                        <tr>
                            <td>
                                @if (car.Image != null)
                                {
                                    string carBase64 = Convert.ToBase64String(car.Image);
                                    <img src="data:image/jpeg;base64,@carBase64" class="img-thumbnail" style="width: 80px; height: 50px; object-fit: cover;" />
                                }
                            </td>
                            <td><strong>@car.Brand</strong><br/><span class="text-muted">@car.Model (@car.Year)</span></td>
                            <td><span class="badge bg-secondary">@(car.Owner?.Username ?? "Bilinmiyor")</span></td>
                            <td>@car.DailyPrice.ToString("C")</td>
                            <td>
                                <form asp-controller="Car" asp-action="Approve" asp-route-id="@car.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-success">✅ Onayla ve Yayınla</button>
                                </form>
                                <form asp-controller="Car" asp-action="Delete" asp-route-id="@car.Id" method="post" style="display:inline;" onsubmit="return confirm('Bu aracı kalıcı olarak reddedip silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-sm btn-danger">❌ Reddet ve Sil</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted p-4">Şu an onay bekleyen araç bulunmuyor.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>